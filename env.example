# Database
DATABASE_URL="postgresql://user:password@localhost:5432/socialbridge?schema=public"

# Redis (BullMQ)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# Encryption
ENCRYPTION_KEY="12345678901234567890123456789012" # Must be 32 chars

# Social Secrets
TWITTER_CLIENT_ID="TWITTER_xxxxx"
TWITTER_CLIENT_SECRET="TWITTER_SECRET_xxxxx"

FACEBOOK_APP_ID="FACEBOOK_xxxxx"
FACEBOOK_APP_SECRET="FACEBOOK_SECRET_xxxxx"

INSTAGRAM_CLIENT_ID="INSTAGRAM_xxxxx"
INSTAGRAM_CLIENT_SECRET="INSTAGRAM_SECRET_xxxxx"

TIKTOK_CLIENT_KEY="TIKTOK_xxxxx"
TIKTOK_CLIENT_SECRET="TIKTOK_SECRET_xxxxx"

LINKEDIN_CLIENT_ID="LINKEDIN_xxxxx"
LINKEDIN_CLIENT_SECRET="LINKEDIN_SECRET_xxxxx"

YOUTUBE_CLIENT_ID="YOUTUBE_xxxxx"
YOUTUBE_CLIENT_SECRET="YOUTUBE_SECRET_xxxxx"

PINTEREST_CLIENT_ID="PINTEREST_xxxxx"
PINTEREST_CLIENT_SECRET="PINTEREST_SECRET_xxxxx"
